{
  "name": "enshou",
  "type": "module",
  "scripts": {
    "build": "pnpm run -r build",
    "test": "pnpm run -r test",
    "fmt": "oxfmt",
    "lint": "oxlint",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@swc/core": "catalog:",
    "@types/bun": "^1.3.14",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "oxlint-tsgolint": "^0.23.0",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "unplugin-swc": "catalog:",
    "vitest": "catalog:"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm build && pnpm lint-staged && pnpm test",
    "prepare-commit-msg": "bun ./scripts/prepare-commit-msg $1"
  },
  "lint-staged": {
    "*": [
      "oxlint",
      "oxfmt"
    ]
  }
}
